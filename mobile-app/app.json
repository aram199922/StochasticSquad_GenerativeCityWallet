{
  "expo": {
    "name": "City Wallet",
    "slug": "generative-city-wallet",
    "version": "1.0.0",
    "scheme": "citywallet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stochasticsquad.citywallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.stochasticsquad.citywallet"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "City Wallet uses your location to find nearby offers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
