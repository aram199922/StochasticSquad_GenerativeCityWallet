# Copy this file to .env — the app works without ANY keys (falls back to stub).
# Add ONE of the keys below to enable real generative offers.
# Priority: Groq → Gemini → Mistral → OpenAI → stub

# ── OPTION 1: Groq (recommended — free, open-weight Llama 3.1 8B, very fast) ──
# Sign up free: https://console.groq.com
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant   # default — other options: llama-3.3-70b-versatile, gemma2-9b-it

# ── OPTION 2: Google Gemini (free tier) ──
# Sign up free: https://aistudio.google.com
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── OPTION 3: Mistral AI (free tier) ──
# Sign up free: https://console.mistral.ai
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-small-latest

# ── OPTION 4: OpenAI (paid) ──
# OPENAI_API_KEY=sk-...

# ── Context signals (both optional — stubs used when absent) ──
# OPENWEATHER_API_KEY=...
# TAVILY_API_KEY=tvly-...
